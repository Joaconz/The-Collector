              "raw": "{\n  \"vendedorId\": 2,\n  \"producto\": {\n    \"nombre\": \"Cámara Leica M3 (1954)\",\n    \"descripcion\": \"Cámara telemétrica de 35mm\",\n    \"historia\": \"Usada por un fotógrafo en los 60\",\n    \"precio\": 3200.50,\n    \"stock\": 1,\n    \"categoria\": \"Cámaras\"\n  }\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "http://localhost:8080/api/publicaciones", "host": ["localhost"], "port": "8080", "path": ["api", "publicaciones"] }
