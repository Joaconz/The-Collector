{
  "info": {
    "name": "The Collector - TPO V2",
    "description": "Endpoints expandidos para el primer avance con seguridad JWT incorporada.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{jwt_token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Status",
      "request": {
        "method": "GET",
        "url": { "raw": "http://localhost:8080/status", "host": ["localhost"], "port": "8080", "path": ["status"] }
      }
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if(pm.response.code === 201 || pm.response.code === 200) {",
                  "    let responseData = pm.response.json();",
                  "    if (responseData.token) {",
                  "        pm.collectionVariables.set(\"jwt_token\", responseData.token);",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Joaquin\",\n  \"email\": \"user@test.com\",\n  \"password\": \"1234\",\n  \"rol\": \"COMPRADOR\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "http://localhost:8080/api/auth/register", "host": ["localhost"], "port": "8080", "path": ["api", "auth", "register"] }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if(pm.response.code === 200) {",
                  "    let responseData = pm.response.json();",
                  "    if (responseData.token) {",
                  "        pm.collectionVariables.set(\"jwt_token\", responseData.token);",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@test.com\",\n  \"password\": \"1234\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "http://localhost:8080/api/auth/login", "host": ["localhost"], "port": "8080", "path": ["api", "auth", "login"] }
          }
        }
      ]
    },
    {
      "name": "Productos",
      "item": [
        {
          "name": "Listar",
          "request": { "method": "GET", "url": { "raw": "http://localhost:8080/api/productos", "host": ["localhost"], "port": "8080", "path": ["api", "productos"] } }
        },
        {
          "name": "Obtener por Id",
          "request": { "method": "GET", "url": { "raw": "http://localhost:8080/api/productos/1", "host": ["localhost"], "port": "8080", "path": ["api", "productos", "1"] } }
        },
        {
          "name": "Crear",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Item Prueba\",\n  \"descripcion\": \"Descripción del item\",\n  \"precio\": 1000.00,\n  \"stock\": 5,\n  \"categoria\": \"Coleccionables\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "http://localhost:8080/api/productos", "host": ["localhost"], "port": "8080", "path": ["api", "productos"] }
          }
        },
        {
          "name": "Actualizar",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Item Prueba Modificado\",\n  \"descripcion\": \"Descripción actualizada\",\n  \"precio\": 1500.00,\n  \"stock\": 10,\n  \"categoria\": \"Coleccionables\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "http://localhost:8080/api/productos/1", "host": ["localhost"], "port": "8080", "path": ["api", "productos", "1"] }
          }
        },
        {
          "name": "Eliminar",
          "request": { "method": "DELETE", "url": { "raw": "http://localhost:8080/api/productos/1", "host": ["localhost"], "port": "8080", "path": ["api", "productos", "1"] } }
        }
      ]
    },
    {
      "name": "Órdenes",
      "item": [
        {
          "name": "Listar",
          "request": { "method": "GET", "url": { "raw": "http://localhost:8080/api/ordenes", "host": ["localhost"], "port": "8080", "path": ["api", "ordenes"] } }
        },
        {
          "name": "Obtener por Id",
          "request": { "method": "GET", "url": { "raw": "http://localhost:8080/api/ordenes/1", "host": ["localhost"], "port": "8080", "path": ["api", "ordenes", "1"] } }
        },
        {
          "name": "Crear (Checkout)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"compradorId\": 1,\n  \"productoIds\": [1, 2]\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "http://localhost:8080/api/ordenes", "host": ["localhost"], "port": "8080", "path": ["api", "ordenes"] }
          }
        }
      ]
    },
    {
      "name": "Publicaciones",
      "item": [
        {
          "name": "Listar",
          "request": { "method": "GET", "url": { "raw": "http://localhost:8080/api/publicaciones", "host": ["localhost"], "port": "8080", "path": ["api", "publicaciones"] } }
        },
        {
          "name": "Crear",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"vendedorId\": 2,\n  \"producto\": {\n    \"nombre\": \"Cámara Leica M3 (1954)\",\n    \"descripcion\": \"Cámara telemétrica de 35mm\",\n    \"historia\": \"Usada por un fotógrafo en los 60\",\n    \"precio\": 3200.50,\n    \"stock\": 1,\n    \"categoria\": \"Cámaras\"\n  }\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "http://localhost:8080/api/publicaciones", "host": ["localhost"], "port": "8080", "path": ["api", "publicaciones"] }
          }
        },
        {
          "name": "Cambiar Estado",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"estado\": \"REACTIVADA\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "http://localhost:8080/api/publicaciones/1", "host": ["localhost"], "port": "8080", "path": ["api", "publicaciones", "1"] }
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "jwt_token",
      "value": "",
      "type": "string"
    }
  ]
}
