{
  "info": {
    "name": "The Collector - TPO V2",
    "description": "Endpoints expandidos para el primer avance",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Status",
      "request": {
        "method": "GET",
        "url": { "raw": "http://localhost:8080/status", "host": ["localhost"], "port": "8080", "path": ["status"] }
      }
    },
    {
