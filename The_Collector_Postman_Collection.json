            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Item Prueba\",\n  \"descripcion\": \"Descripción del item\",\n  \"precio\": 1000.00,\n  \"stock\": 5,\n  \"categoria\": \"Coleccionables\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "http://localhost:8080/api/productos", "host": ["localhost"], "port": "8080", "path": ["api", "productos"] }
          }
        },
        {
          "name": "Actualizar",
